NODE_ENV=development

# Monolith runtime
PORT=4000
MONOLITH_PORT=4000
MONOLITHIC_MODE=true

# Database
MONGO_URI=mongodb://localhost:27017/campus_club
MONGO_DB_NAME=campus_club
TEST_MONGO_URI=mongodb://localhost:27017/campus_club_test
TEST_DB_NAME=campus_club_test

# Auth
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
JWT_OTP_EXPIRES_IN=10m
SERVICE_AUTH_KEY=change-this-internal-key
API_PUBLIC_BASE_URL=http://localhost:4000/api/v1
FRONTEND_VERIFY_EMAIL_URL=http://localhost:5173/verify-email
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
LOGIN_OTP_TTL_MINUTES=10

# HTTP Security
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
DISABLE_RATE_LIMIT=false

# Logging
LOG_DIR=./logs
ENABLE_FILE_LOGS=true

# Cloudinary (optional for direct image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (optional but recommended for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Campus Club <no-reply@campusclub.local>

# Default seeded admin (created only if not existing)
ENABLE_DEFAULT_ADMIN_SEED=false
DEFAULT_ADMIN_NAME=Club Admin
DEFAULT_ADMIN_EMAIL=admin@campusclub.local
DEFAULT_ADMIN_PASSWORD=Admin@1234
