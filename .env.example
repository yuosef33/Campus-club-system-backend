NODE_ENV=development

# Shared
MONGO_URI=mongodb://localhost:27017/campus_club
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
SERVICE_AUTH_KEY=change-this-internal-key
API_PUBLIC_BASE_URL=http://localhost:4000/api/v1
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/verify-email
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
LOG_DIR=./logs
ENABLE_FILE_LOGS=true

# Optional RabbitMQ
AMQP_URL=amqp://localhost:5672
AMQP_EXCHANGE=campus-club.events

# Cloudinary (optional for direct image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (optional but recommended for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Campus Club <no-reply@campusclub.local>

# Default seeded admin (created only if not existing)
DEFAULT_ADMIN_NAME=Club Admin
DEFAULT_ADMIN_EMAIL=admin@campusclub.local
DEFAULT_ADMIN_PASSWORD=Admin@1234

# API gateway + services ports
PORT=4000
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
EVENT_SERVICE_PORT=4002
RSVP_SERVICE_PORT=4003
ANNOUNCEMENT_SERVICE_PORT=4004
GALLERY_SERVICE_PORT=4005

# Database names per service
AUTH_DB_NAME=campus_auth
EVENT_DB_NAME=campus_event
RSVP_DB_NAME=campus_rsvp
ANNOUNCEMENT_DB_NAME=campus_announcement
GALLERY_DB_NAME=campus_gallery

# Service URLs for gateway and inter-service calls
AUTH_SERVICE_URL=http://localhost:4001
EVENT_SERVICE_URL=http://localhost:4002
RSVP_SERVICE_URL=http://localhost:4003
ANNOUNCEMENT_SERVICE_URL=http://localhost:4004
GALLERY_SERVICE_URL=http://localhost:4005
