          }
        },
        {
          "name": "Approve User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/{{userId}}/approve"
          }
        },
        {
          "name": "Reject User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/{{userId}}/reject"
          }
        },
        {
          "name": "Import Members CSV (Approved + Verified)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/admin/users/import-csv",
            "description": "CSV headers must include email and one of displayName/display_name/name/full_name."
          }
        }
      ]
